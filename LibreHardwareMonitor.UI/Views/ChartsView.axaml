<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LibreHardwareMonitor.UI.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="LibreHardwareMonitor.UI.Views.ChartsView"
             x:DataType="vm:ChartsViewModel">

    <Grid RowDefinitions="Auto,*" Margin="24">

        <!-- Header + Category tabs -->
        <StackPanel Spacing="12" Margin="0,0,0,16">
            <TextBlock Text="Charts" Classes="section-header" FontSize="22" Margin="0" />

            <!-- Category tabs -->
            <Border Background="{StaticResource BgCardBrush}"
                    CornerRadius="10" Padding="4"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Content="{Binding}"
                                    Command="{Binding $parent[UserControl].((vm:ChartsViewModel)DataContext).SelectCategoryCommand}"
                                    CommandParameter="{Binding}"
                                    Classes="nav-item"
                                    Padding="16,8"
                                    FontSize="12"
                                    FontWeight="SemiBold" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>

        <!-- Chart + Legend -->
        <Grid Grid.Row="1" ColumnDefinitions="*,240">

            <!-- Chart area -->
            <Border Classes="card" Padding="16" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SelectedCategory}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <Border Background="{StaticResource BgSecondaryBrush}" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="{Binding YAxisUnit}" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiaryBrush}" />
                        </Border>
                    </StackPanel>

                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding Series}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        ZoomMode="X"
                                        TooltipPosition="Top"
                                        AnimationsSpeed="00:00:00.100"
                                        Background="Transparent"
                                        LegendPosition="Hidden" />
                </Grid>
            </Border>

            <!-- Legend panel with current values -->
            <Border Grid.Column="1" Classes="card" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="SENSORS" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8" />

                    <ItemsControl ItemsSource="{Binding SensorLegend}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ChartSensorInfo">
                                <Border Padding="0,6"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding Color}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Name}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="190" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding CurrentValue}" FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="14,0,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
