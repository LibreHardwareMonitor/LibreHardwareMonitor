<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LibreHardwareMonitor.UI.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="LibreHardwareMonitor.UI.Views.ChartsView"
             x:DataType="vm:ChartsViewModel">

    <Grid RowDefinitions="Auto,*" Margin="24">

        <!-- Header + Category tabs -->
        <StackPanel Spacing="12" Margin="0,0,0,16">
            <TextBlock Text="Charts" Classes="section-header" FontSize="22" Margin="0" />

            <!-- Category tabs -->
            <Border Background="{StaticResource BgCardBrush}"
                    CornerRadius="10" Padding="4"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Content="{Binding}"
                                    Command="{Binding $parent[UserControl].((vm:ChartsViewModel)DataContext).SelectCategoryCommand}"
                                    CommandParameter="{Binding}"
                                    Classes="nav-item"
                                    Padding="16,8"
                                    FontSize="12"
                                    FontWeight="SemiBold" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
            <!-- Time window + stroke -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ItemsControl ItemsSource="{Binding TimeWindows}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Button Content="{Binding}" Padding="10,4" FontSize="10" Cursor="Hand"
                                    Background="{StaticResource BgSecondaryBrush}"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    CornerRadius="4" BorderThickness="0"
                                    Command="{Binding $parent[UserControl].((vm:ChartsViewModel)DataContext).SelectTimeWindowCommand}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Stroke:" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
                <Slider Minimum="1" Maximum="5" Value="{Binding StrokeThickness}"
                        Width="80" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <!-- Chart + Sensor picker + Legend -->
        <Grid Grid.Row="1" ColumnDefinitions="*,260">

            <!-- Chart area -->
            <Border Classes="card" Padding="16" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,*">
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SelectedCategory}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <Border Background="{StaticResource BgSecondaryBrush}" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="{Binding YAxisUnit}" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextTertiaryBrush}" />
                        </Border>
                    </StackPanel>

                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding Series}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        ZoomMode="X"
                                        TooltipPosition="Top"
                                        AnimationsSpeed="00:00:00.100"
                                        Background="Transparent"
                                        LegendPosition="Hidden" />
                </Grid>
            </Border>

            <!-- Right panel: sensor picker + legend -->
            <Border Grid.Column="1" Classes="card" Padding="16">
                <Grid RowDefinitions="Auto,*,Auto,Auto">

                    <!-- Sensor picker header -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="SENSOR SELECTION" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                        <TextBlock Text="{Binding SelectionInfo}" FontSize="10"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4" />
                    </StackPanel>

                    <!-- Scrollable sensor checkboxes -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableSensors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SelectableSensor">
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              Padding="4,2" Margin="0,1">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="10"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="190"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Divider -->
                    <Border Grid.Row="2" Height="1" Margin="0,8"
                            Background="{StaticResource BorderSubtleBrush}" />

                    <!-- Active sensor legend -->
                    <StackPanel Grid.Row="3" Spacing="4">
                        <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4" />
                        <ItemsControl ItemsSource="{Binding SensorLegend}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChartSensorInfo">
                                    <Border Padding="0,4"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding Color}" />
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Name}" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="190" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding CurrentValue}" FontSize="12" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Margin="14,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
