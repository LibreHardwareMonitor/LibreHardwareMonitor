<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://LibreHardwareMonitor.UI/Styles/Colors.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- Sidebar nav button -->
    <Style Selector="Button.nav-item">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.nav-item.active">
        <Setter Property="Background" Value="#1F2A3D" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.nav-item.active /template/ ContentPresenter">
        <Setter Property="Background" Value="#1F2A3D" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Card panel -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource BgCardBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!-- Section header text -->
    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!-- Sensor value large -->
    <Style Selector="TextBlock.sensor-value">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Sensor label -->
    <Style Selector="TextBlock.sensor-label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <!-- Sensor unit -->
    <Style Selector="TextBlock.sensor-unit">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
        <Setter Property="Margin" Value="4,0,0,2" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
    </Style>

    <!-- Status indicator dot -->
    <Style Selector="Ellipse.status-dot">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
    </Style>

    <!-- Window control buttons -->
    <Style Selector="Button.window-control">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="46" />
    </Style>
    <Style Selector="Button.window-control:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2A3142" />
    </Style>
    <Style Selector="Button.window-close:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#C42B1C" />
    </Style>
</Styles>
